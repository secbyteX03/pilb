# ╔════════════════════════════════════════════════════════════════╗
# ║          PILB FRONTEND - ENVIRONMENT CONFIGURATION             ║
# ║  Copy this file to .env and fill in your actual values         ║
# ║  Frontend env vars are exposed in the browser, don't put       ║
# ║  secrets here!                                                  ║
# ╚════════════════════════════════════════════════════════════════╝

# ═════════════════════════════════════════════════════════════════
# VITE BUILD CONFIGURATION
# ═════════════════════════════════════════════════════════════════

# Backend API URL (where requests are sent)
# For local development: http://localhost:3000/api
# For production: https://api.pilb.app/api
VITE_API_URL=http://localhost:3000/api

# API request timeout (milliseconds)
VITE_API_TIMEOUT=30000

# Application name
VITE_APP_NAME=PILB

# Application version
VITE_APP_VERSION=1.0.0


# ═════════════════════════════════════════════════════════════════
# STELLAR NETWORK CONFIGURATION
# ═════════════════════════════════════════════════════════════════

# Stellar network (testnet or mainnet)
# ⚠️ ONLY use mainnet when going to production!
VITE_STELLAR_NETWORK=testnet

# Stellar server URL
VITE_STELLAR_SERVER_URL=https://horizon-testnet.stellar.org


# ═════════════════════════════════════════════════════════════════
# ANALYTICS & MONITORING (OPTIONAL)
# ═════════════════════════════════════════════════════════════════

# Google Analytics ID (if using GA)
VITE_GA_ID=

# Sentry DSN for error tracking (if using Sentry)
VITE_SENTRY_DSN=

# PostHog key for product analytics (if using PostHog)
VITE_POSTHOG_KEY=


# ═════════════════════════════════════════════════════════════════
# FEATURE FLAGS (OPTIONAL)
# ═════════════════════════════════════════════════════════════════

# Enable/disable features in development
VITE_ENABLE_TESTNET=true
VITE_ENABLE_MAINNET=false
VITE_ENABLE_DEBUG_MODE=true
VITE_ENABLE_ANALYTICS=false


# ═════════════════════════════════════════════════════════════════
# BUILD & DEPLOYMENT
# ═════════════════════════════════════════════════════════════════

# Mode (development, staging, production)
VITE_MODE=development

# Source maps in production (true = larger bundles, better debugging)
VITE_GENERATE_SOURCEMAP=true
