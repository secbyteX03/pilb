# ╔════════════════════════════════════════════════════════════════╗
# ║           PILB BACKEND - ENVIRONMENT CONFIGURATION             ║
# ║  Copy this file to .env and fill in your actual values         ║
# ║  NEVER commit .env with real credentials to GitHub!            ║
# ╚════════════════════════════════════════════════════════════════╝

# ═════════════════════════════════════════════════════════════════
# APPLICATION SETTINGS
# ═════════════════════════════════════════════════════════════════

# Environment mode (development, staging, production)
NODE_ENV=development

# Server port
PORT=3000

# API base URL (for callbacks, etc)
API_URL=http://localhost:3000


# ═════════════════════════════════════════════════════════════════
# DATABASE CONFIGURATION (PostgreSQL)
# ═════════════════════════════════════════════════════════════════

# Database connection - choose one method:

# METHOD 1: Individual components
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pilb
DB_USER=postgres
DB_PASSWORD=your_secure_password

# METHOD 2: Single connection string (optional, overrides above)
# DATABASE_URL=postgresql://postgres:password@localhost:5432/pilb


# ═════════════════════════════════════════════════════════════════
# STELLAR NETWORK CONFIGURATION
# ═════════════════════════════════════════════════════════════════

# Network selection
# Options: testnet (development) or mainnet (production)
STELLAR_NETWORK=testnet

# Stellar API endpoint
STELLAR_SERVER_URL=https://horizon-testnet.stellar.org

# Your SERVICE PROVIDER Stellar Public Key
# (This is the account that receives payments)
# Get from: https://laboratory.stellar.org
SERVICE_WALLET_ADDRESS=GXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Your SERVICE PROVIDER Stellar Secret Key
# ⚠️ KEEP THIS SECURE! Never share or commit!
# Get from: https://laboratory.stellar.org
SERVICE_WALLET_SECRET=SXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX


# ═════════════════════════════════════════════════════════════════
# M-PESA / SAFARICOM DARAJA API
# ═════════════════════════════════════════════════════════════════

# Get these from: https://developer.safaricom.co.ke/
# 1. Create a Safaricom developer account
# 2. Create an app
# 3. Copy credentials below

# OAuth2 Credentials (for getting access tokens)
MPESA_CONSUMER_KEY=your_daraja_consumer_key_here
MPESA_CONSUMER_SECRET=your_daraja_consumer_secret_here

# Safaricom API Base URL
# For sandbox/testing: https://sandbox.safaricom.co.ke
# For production: https://api.safaricom.co.ke
MPESA_BASE_URL=https://sandbox.safaricom.co.ke

# Your M-Pesa Business Shortcode
# Example: 600XXX (for paybill) or 808XXX (for till)
MPESA_SHORTCODE=600000

# Your M-Pesa Passkey
# Get from Safaricom developer console
MPESA_PASSKEY=your_mpesa_passkey_here

# Callback URL for M-Pesa responses
# This is where Safaricom will send payment confirmations
# For local development, use ngrok or similar to expose your server
MPESA_CALLBACK_URL=http://localhost:3000/api/mpesa/callback

# M-Pesa Initiator Credentials (for B2C payments)
MPESA_INITIATOR_NAME=your_initiator_name
MPESA_INITIATOR_PASSWORD=your_initiator_password


# ═════════════════════════════════════════════════════════════════
# ENCRYPTION & SECURITY
# ═════════════════════════════════════════════════════════════════

# AES-256 encryption key for sensitive data
# ⚠️ MUST be at least 32 characters
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-secret-key-min-32-chars-change-in-production


# ═════════════════════════════════════════════════════════════════
# FRONTEND CONFIGURATION
# ═════════════════════════════════════════════════════════════════

# Frontend URL (for CORS and redirects)
FRONTEND_URL=http://localhost:5173


# ═════════════════════════════════════════════════════════════════
# LOGGING
# ═════════════════════════════════════════════════════════════════

# Log level (trace, debug, info, warn, error, fatal)
# Use 'debug' for development, 'info' for production
LOG_LEVEL=debug


# ═════════════════════════════════════════════════════════════════
# OPTIONAL: SMS NOTIFICATIONS (Twilio)
# ═════════════════════════════════════════════════════════════════
# Only needed if you want to send SMS to users
# Get credentials from: https://www.twilio.com/console

# Twilio Account SID
TWILIO_ACCOUNT_SID=your_twilio_account_sid

# Twilio Auth Token
TWILIO_AUTH_TOKEN=your_twilio_auth_token

# Twilio Phone Number (sender)
# Format: +254712345678
TWILIO_PHONE=+254712345678


# ═════════════════════════════════════════════════════════════════
# OPTIONAL: EMAIL SERVICE (SendGrid / Mailgun)
# ═════════════════════════════════════════════════════════════════

# SendGrid API Key (if using SendGrid for emails)
SENDGRID_API_KEY=your_sendgrid_api_key

# Email from address
EMAIL_FROM=noreply@pilb.app


# ═════════════════════════════════════════════════════════════════
# OPTIONAL: CORS & SECURITY HEADERS
# ═════════════════════════════════════════════════════════════════

# Allowed origins for CORS (comma-separated)
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# Rate limiting (requests per minute)
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100
